<%- include('./partials/header') %>

<section class="trains-hero">
    <h1>Learn about our Trains</h1>
    <p>
        Explore the physical trains that power scenic the trips across the Kizuna Rail network.
    </p>
</section>

<section class="trains-catalog">
    <div class="trains-state" id="trains-loading">Loading trains...</div>
    <div class="trains-state trains-error" id="trains-error" hidden></div>

    <div class="trains-grid" id="trains-list"></div>

    <template id="train-card-template">
        <article class="train-card">
            <div class="train-image-wrap">
                <img data-field="image" loading="lazy" decoding="async">
            </div>

            <header class="train-card-header">
                <h2 data-field="name"></h2>
                <span class="train-operator" data-field="operator"></span>
            </header>

            <p class="train-description" data-field="description"></p>

            <dl class="train-specs">
                <div class="spec-item">
                    <dt>Type</dt>
                    <dd data-field="type"></dd>
                </div>
                <div class="spec-item">
                    <dt>Top Speed</dt>
                    <dd data-field="speed"></dd>
                </div>
                <div class="spec-item">
                    <dt>Capacity</dt>
                    <dd data-field="seats"></dd>
                </div>
                <div class="spec-item">
                    <dt>Power</dt>
                    <dd data-field="power"></dd>
                </div>
            </dl>

            <p class="train-best-for">
                <strong>Best For:</strong>
                <span data-field="best-for"></span>
            </p>
        </article>
    </template>
</section>

<%- include('./partials/footer') %>
